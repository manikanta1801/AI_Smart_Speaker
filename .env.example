# ──────────────────────────────────────────────
#  Mi Gemini Speaker — Environment Variables
# ──────────────────────────────────────────────
#
#  HOW TO USE:
#    1. Copy this file to a new file named `.env`
#    2. Fill in your actual values below
#    3. NEVER commit the `.env` file to GitHub!
#
# ──────────────────────────────────────────────

# Get your FREE Gemini API key from:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_api_key_here

# (Optional) Gemini model to use
# Options: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# (Optional) Max tokens for each Gemini response
# Keep low for faster, concise voice responses
GEMINI_MAX_TOKENS=300
