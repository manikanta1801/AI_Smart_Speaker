# ──────────────────────────────────────────────
#  Mi AI Speaker — Environment Variables
# ──────────────────────────────────────────────
#
#  HOW TO USE:
#    1. Copy this file to a new file named `.env`
#    2. Fill in your actual values below
#    3. NEVER commit the `.env` file to GitHub!
#
# ──────────────────────────────────────────────

# Get your FREE DeepSeek API key from:
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk_your_api_key_here

# (Optional) DeepSeek model to use
# Options: deepseek-chat, deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# (Optional) Max tokens for each AI response
# Keep low for faster, concise voice responses
DEEPSEEK_MAX_TOKENS=300
